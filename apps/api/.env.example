PORT=4000

# Bill OCR engine: "openrouter" (vision LLM) or "tesseract" (local, no key).
# Defaults to openrouter when OPENROUTER_API_KEY is set, else tesseract.
OCR_PROVIDER=
# OpenRouter API key (get one at openrouter.ai). Needed for OCR_PROVIDER=openrouter.
# NOTE: the default model is a FREE endpoint that LOGS inputs for training —
# dev/demo only, do not send real user bills. Use a paid no-logging model for prod.
OPENROUTER_API_KEY=
# Optional: override the vision model (default nvidia/nemotron-nano-12b-v2-vl:free).
OCR_MODEL=

# Supabase (next phase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (next phase)
OPENAI_API_KEY=
